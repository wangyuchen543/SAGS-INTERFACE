<!-- 节点之间的通信连接关系 -->
  <links>
    
    <!-- ==================== 卫星通信 (HIBS) ==================== -->
      <!-- HIBS1 ↔ HIBS2 -->
    <link>
      <node1>HIBS1</node1>
      <node2>HIBS2</node2>
      <commType>Satellite</commType>
    </link>
    
    <!-- HIBS2 ↔ HIBS3 -->
    <link>
      <node1>HIBS2</node1>
      <node2>HIBS3</node2>
      <commType>Satellite</commType>
    </link>
    
    <!-- HIBS3 ↔ HIBS4 -->
    <link>
      <node1>HIBS3</node1>
      <node2>HIBS4</node2>
      <commType>Satellite</commType>
    </link>
  
    
 
    
