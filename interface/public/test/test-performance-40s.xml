<?xml version="1.0" encoding="UTF-8"?>
<performance>
  <!-- 仿真时间（秒） -->
  <simulationTime>40</simulationTime>
  
 
  
  <!-- 整体性能指标 -->
  <overall>
    <throughput>2150.8</throughput>
    <delay>22.6</delay>
    <transmissionRate>1480.3</transmissionRate>
    <packetLoss>2.3</packetLoss>
  </overall>
  
  <!-- 业务类型A的性能指标 -->
  <business type="A">
    <throughput>580.5</throughput>
    <delay>19.2</delay>
    <transmissionRate>420.8</transmissionRate>
    <packetLoss>1.9</packetLoss>
  </business>
  
  <!-- 业务类型B的性能指标 -->
  <business type="B">
    <throughput>720.6</throughput>
    <delay>24.8</delay>
    <transmissionRate>510.2</transmissionRate>
    <packetLoss>2.6</packetLoss>
  </business>
  
  <!-- 业务类型C的性能指标 -->
